<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Lambda name="LAMBDA">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} &lt;%X{AWSRequestId}&gt; %-5p %c:%L - %m%n"/>
        </Lambda>
    </Appenders>
    <Loggers>
        <Root level="DEBUG">
            <AppenderRef ref="LAMBDA"/>
        </Root>
    </Loggers>
</Configuration>
